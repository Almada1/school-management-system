# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=school_db
DB_PORT=3306

# Application Settings
APP_NAME="Système de Gestion d'École"
APP_URL=http://localhost/school-management-system
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris

# Session & Security
SESSION_TIMEOUT=3600
REMEMBER_ME_DURATION=2592000
ENCRYPTION_KEY=your_secret_encryption_key_here

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_password
MAIL_FROM=noreply@school.local
MAIL_FROM_NAME="Système Scolaire"

# SMS Configuration (optional)
SMS_API_KEY=your_sms_api_key
SMS_SENDER=SCHOOL

# File Upload
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif

# Backup Settings
BACKUP_PATH=/backups
BACKUP_AUTO=true
BACKUP_RETENTION_DAYS=30

# API Keys
API_SECRET=your_api_secret_key
API_RATE_LIMIT=100

# School Information
SCHOOL_NAME="École Primaire Excellence"
SCHOOL_LOGO=/public/images/logo.png
SCHOOL_ADDRESS="123 Rue de l'École, 75000 Paris"
SCHOOL_PHONE="+33 1 23 45 67 89"
SCHOOL_EMAIL=info@school.local
SCHOOL_WEBSITE=www.school.local

# Academic Year
ACADEMIC_YEAR_START=2025-09-01
ACADEMIC_YEAR_END=2026-06-30
